/**index.wxss**/
page{
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #EAF0FB;
  /* background-color: red; */
}
/* .scrollarea {
  flex: 1;
  overflow-y: hidden;
} */
.banner{
  background: linear-gradient(90deg,#1296db,#6C9DFF);
  border-radius: 32rpx;
  height: 180rpx;
  width: 700rpx;
  position: absolute;
  margin-top: 25rpx;
  margin-left: 25rpx;
}
.banner-mainhead{
  position: absolute;
  color: aliceblue;
  font-size: 48rpx;
  margin-left: 25rpx;
  margin-top: 22rpx;
}
.banner-subhead{
  position: absolute;
color: aliceblue;
font-size: 35rpx;
margin-left: 25rpx;
margin-top: 96rpx;
}

/* 设备分类容器 */
.device-category {
  margin-top: 240rpx;
  margin-left: 25rpx;
  margin-bottom: 30rpx;
}
/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}








.Equipment-List-Area{
  margin-top:  10rpx;
  margin-left: auto;
  margin-right: auto;
}

.DeviceList{
  display: flex;
  flex-direction: column;
  height: 580rpx;
  width: 695rpx;
  border-radius: 30rpx; 
  overflow: hidden;
  border-radius: 20rpx;
}

.ImageCard{
  width: 100%;
 height: 300rpx;
 background-color: #1296db;
 /* border-radius: 20rpx 20rpx 0rpx 0rpx;  */
}
.ImageCard image{
width: 100%;
height: 100%;
}

 .DeviceInformation{
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height:210rpx;
  width: 100%;
  background-color: #FFF;
  border-radius: 0 0 20rpx 20rpx;
  /* border-bottom: 3rpx outset #34c759; */
}

.Dione{
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 88%;
  height: 50rpx;
 margin-top: 8rpx;
}
.Ditwo{
  width: 88%;
  /* background-color: red; */
  font-size: 26rpx;
  color: #666666;
  word-wrap: break-word;
}

.Dithree{
  width: 88%;
  height: 50rpx;
  display: flex;
  align-items: center;
  font-size: 23rpx;
  /* justify-content: space-between; */
}
.DeviceSite{
  /* width: 150rpx; */
  height: 100%;
  font-size: 24rpx;
  color: #666666;
  margin-left: 10rpx;
 
}

.category {
  /* display: inline-block; */
  align-self: center;
  text-align: center;
  margin-bottom: 20rpx;
  margin-left: 30rpx;
  padding: 6rpx 16rpx;
  background-color: #f2f2f7;
  color: #8e8e93;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.Dithree image{
  width: 42rpx;
  height: 40rpx;
  margin-bottom: 18rpx;
}

.status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
  min-width: 80rpx;
  text-align: center;
  border: 2rpx solid transparent;
}
.available{
  background-color: rgba(52, 199, 89, 0.1);
  color: #34c759;
  border-color: rgba(52, 199, 89, 0.3);
}
.unavailable{
  background-color: rgba(203, 232, 210, 0.1);
  color: #707e9b;
  border-color: rgba(52, 199, 89, 0.3);
}

.DeviceName{
  font-size: 35rpx;
  font-weight: bold;
}


/* 横向滚动容器 */
.categoryBar{
  white-space: nowrap;
  margin-top: 230rpx;
  padding: 20rpx;
}

/* 分类按钮样式 */
.categoryBar button{
  display: inline-block;
  flex-shrink: 0;  
  margin-left: 10rpx;    
  padding: 0 20rpx;          
  min-width: 0;          
  line-height: 80rpx;   
  text-align: center;   
  border: 1rpx solid #eee; 
  border-radius: 80rpx; 
  background-color: #fff; 
  font-size: 28rpx;   
}

.categoryBar button.selected {
  background-color: #336de0; /* 选中时的背景色 */
  color: #fff;
}
