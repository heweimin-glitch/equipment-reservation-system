/* pages/my/my.wxss */
page{
  background-color: #EAF0FB;
}
.banner{
  background: linear-gradient(90deg,#1296db,#6C9DFF);
  border-radius: 32rpx;
  height: 200rpx;
  width: 700rpx;
  position: relative;
  margin-top: 25rpx;
  margin-bottom: 25rpx;
  margin-left: 25rpx;
  display: flex;
  align-items: center;
}
.banner .AvatarArea{
  position: absolute;
  height: 150rpx;
  width: 150rpx;
  margin-left: 10%;
  background-color: whitesmoke; 
  border-radius: 75rpx;
  /* overflow: hidden; */
}

.banner .PersonalInformation{
  position: absolute;
  display: flex;
  height: 150rpx;
  width: 350rpx;
  /* background-color: beige; */
  /* border-radius: 10rpx; */
  margin-left: 35%;
  align-items: center;
  flex-direction: column;
}
.PI-name{
  height: 40rpx;
  width: 100%;
  font-size: 30rpx;
  margin-top: 20rpx;
  margin-bottom:15rpx ;
  color: white;
  /* border-bottom: 1rpx solid black; */
}
.PI-class{
  height: 40rpx;
  font-size: 25rpx;
  width: 100%;
  color: whitesmoke;
  margin-left: 5rpx;
  /* border-bottom: 1rpx solid black; */
}

.label{
  display: flex;
  position: relative;
  height: 200rpx;
  width: 700rpx;
  background-color:#FFFFFF;
  margin-left: 25rpx;
  margin-bottom: 8rpx;
  border-radius: 32rpx;
  align-items: center;
}

.label image{
  width: 60rpx;
  height: 60rpx;
  margin-top: auto;
  margin-bottom: auto;
  margin-left: 40rpx;
}
.labelcenter{
  margin-left: 30rpx;
}
.labeltext{
  font-size: 40rpx;
  /* font-weight: bolder; */
}
.textabout{
  font-size: 25rpx;
  color: #666666;
}

.label .funhui{
width: 40rpx;
height: 40rpx;
margin-left: 230rpx;
}

.deviceOP{
  position: relative;
  margin-top: 50rpx;
  margin-left: 25rpx;
  height: 350rpx;
  width: 700rpx;
  border-radius: 32rpx;
  background-color: #FFFFFF;
}

.btn-group {
  display: flex;
  margin-top: 80rpx;
  text-align: center;
}
.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.btn-logout:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.btn {
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  height: 80rpx;
  padding-top:20rpx;
}

.btn-logout {
  margin-left: 20rpx;
  background: linear-gradient(135deg, #ff6a6a, #ff3d3d);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding-top:20rpx;
}