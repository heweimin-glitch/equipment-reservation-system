.page {
  background: #f5f6f7;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 白卡片 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 第一行 */
.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #333;
 
}

.value {
  color:#2F3640;
  font-size: 28rpx;
}

/* 小标题 */
.section-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

/* 时间行 */
.time-row {
  margin-bottom: 24rpx;
}

.time-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 时间选择器 */
.time-group {
  display: flex;
  gap: 20rpx;
}

.time-box {
  background: #f2f3f5;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  min-width: 200rpx;
  min-height: 40rpx;
  text-align: center;
}

/* 输入框 */
.textarea {
  width: 100%;
  height: 220rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 字数 */
.count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
}
.submit-btn {
  background: linear-gradient(135deg, #007AFF, #5856D6);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  margin: 0 30rpx 30rpx;
  margin-top: 30rpx;
}

/* 整体区域卡片化 */
.section {
  margin: 24rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* picker外层盒子 */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: center;

  height: 88rpx;
  padding: 0 20rpx;

  border: 2rpx dashed #dcdcdc;
  border-radius: 12rpx;

  font-size: 28rpx;
  color: #888;

  background: #fafafa;

  transition: all 0.2s ease;
}

/* 选中状态（需要你在js里加条件class或直接替换文字也行） */
.picker-box:active {
  background: #f0f8ff;
  border-color: #4a90e2;
}

/* 有选中值时的视觉强化（推荐配合你JS） */
.picker-box.selected {
  border: 2rpx solid #4a90e2;
  color: #333;
  background: #f5f9ff;
  font-weight: 500;
}

/* picker点击区域增强 */
picker {
  display: block;
}