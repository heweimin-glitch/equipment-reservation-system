page{
  /* background-color: red; */
  background-color: #FEFEFE;
}
.title-container {
  text-align: center;  /* 关键：让内联内容居中 */
  padding: 15rpx 0;
}
.bigtitle {
  display: inline-block;  /* 或者 block */
  font-size: 70rpx;
  color: #3a7be0;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.coverimage{
  position: absolute;
  height: 200rpx;
  width:200rpx ; 
  margin-left: 470rpx;
  background-color: #ffffff;
  /* background-color: red; */
}
.subtitle {
  display: block;  /* 块级元素 */
  color: #666;
  opacity: 0.8;
  font-size: 26rpx;
  margin-top: 10rpx;
}
.topimage{
  width: 200rpx;
  height: 190rpx;
  /* background-color: #111; */
  display: block;          
  margin-left:auto;
  margin-right: auto;
  margin-top: 40rpx;          
}
.container {
  height: 100vh;
  background: linear-gradient(#f2f4f7, #e9edf3);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-top: 120rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #3a7be0;
  margin-top: 20rpx;
}

.card {
  width: 100%;
  border-radius: 20rpx;
  margin-top: 0rpx;
  padding:  30rpx;
}

.label01 {
  margin-top: 140rpx;
  margin-bottom: 10rpx;
  color: #333;
}
.label02{
  margin-top: 30rpx;
  margin-bottom: 10rpx;
  color: #333;
}
.input {
  margin-top: 20rpx;
  background: #f2f3f5;
  border-radius: 15rpx;
  padding: 20rpx;
  width: 85%;
}

.agreement {
  display: flex;
  align-items: center;
  margin-top: 50rpx;
  font-size: 24rpx;
  color: #666;
}

.btn {
  margin-top: 40rpx;
  background: #3a7be0;
  color: #fff;
  border-radius: 40rpx;
}