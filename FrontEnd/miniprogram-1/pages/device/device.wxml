<!--pages/device/device.wxml-->
  <!-- 顶部图片区域 -->
  <image class="DeviceImage" src="{{device.ImageUrl}}" mode="aspectFill"></image>

<!-- 设备卡片容器 -->
<view class="Device-card">
  <!-- 标题区域 -->
  <view class="card-one">


  <view class="header-section">
    <text class="title">
    <text>{{device.name}}</text>
    </text>
    
 </view>

    <!-- 设备描述 -->
    <view class="description">
    <text>{{device.introduction}}</text>
  </view>

  <!-- 位置信息 -->
  <view class="location">
    <icon type="location" size="18" color="#007AFF"></icon>
    <text>{{device.address}}</text>
  </view>
  
  <!-- 分类标签 -->
  <view class="category">
  <text>{{device.category}}</text>
  </view>

</view>
  
  <!-- 设备规格 -->
  <view class="specs">
    <text class="specs-title">
    <text>设备规格</text>
    </text>
    <text class="specs-content">
    <text>{{device.spec}}</text>
    </text>
  </view>
  
  <!-- 使用说明 -->
  <view class="usage-guide">
    <text class="guide-title">使用说明</text>
    <view class="step">
      <text class="step-number">1</text>
      <text class="step-text">点击下方预约按钮选择预约时间</text>
    </view>
    <view class="step">
      <text class="step-number">2</text>
      <text class="step-text">填写预约信息并提交申请</text>
    </view>
    <view class="step">
      <text class="step-number">3</text>
      <text class="step-text">等待管理员确认后即可使用</text>
    </view>
    <view class="step">
      <text class="step-number">4</text>
      <text class="step-text">使用完毕后请及时归还设备</text>
    </view>
  </view>
    
<button
  class="reserve-btn"
  bindtap="onReserveTap"
>
  立即预约
</button>


</view>