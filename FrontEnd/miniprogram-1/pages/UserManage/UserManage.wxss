.page {
  min-height: 100vh;
  background: #f4f6fb;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 标题 */
.title {
  font-size: 42rpx;
  font-weight: 600;
  color: #1d2b3a;
  margin-bottom: 50rpx;
  text-align: center;
}

/* 表单卡片 */
.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
}

/* 每一项 */
.item {
  margin-bottom: 35rpx;
}

/* 标签 */
.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

/* 输入框统一风格 */
.input {
  width: 100%;
  height: 80rpx;
  background: #f6f7fb;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* picker显示框 */
.input-box {
  height: 80rpx;
  line-height: 80rpx;
  background: #f6f7fb;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 按钮 */
.btn {
  margin-top: 50rpx;
  background: linear-gradient(135deg, #3b7cff, #336de0);
  color: #fff;
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 80rpx;
  display: flex;
  justify-content: center; 
  align-items: center;  
  box-shadow: 0 10rpx 20rpx rgba(51,109,224,0.25);
}